# === Application Configuration ===
APP_NAME=Satellite Tracker
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_PRODUCTION=false

# === Database Configuration ===
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/satellite_tracker
TEST_DATABASE_URL=sqlite:///./test_satellite_tracker.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# === Security ===
SECRET_KEY=your-secret-key-here-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_TOKEN=

# === API & CORS ===
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Rate Limiting ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# === Background Jobs & Caching ===
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# === Satellite Data ===
TLE_URL=https://celestrak.org/NORAD/elements/stations.txt
TLE_CACHE_PATH=data/stations.tle
PREDICTION_DAYS=12
MIN_PASS_ELEVATION=10

# === Monitoring (Production) ===
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# === Backups (Production) ===
DB_BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
S3_BUCKET_NAME=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

